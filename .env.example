# ReCoMo environment variables
# Copy this file to .env and set the values you need.
# If you use python-dotenv, ensure .env is loaded at app start (e.g. the demo does this in run_demo.main()).

# -----------------------------------------------------------------------------
# LLM provider and API keys
# -----------------------------------------------------------------------------

# Which LLM API to use: "openai" or "openrouter".
# If unset: openrouter is used when OPENROUTER_API_KEY is set and OPENAI_API_KEY is not;
# otherwise openai is used.
# RECOMO_LLM_PROVIDER=openai

# OpenAI API key. Required when RECOMO_LLM_PROVIDER=openai (or when provider is inferred as openai).
# Get it from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# OpenRouter API key. Required when RECOMO_LLM_PROVIDER=openrouter.
# Get it from https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=sk-or-...

# Model ID for chat/completions. Optional; defaults depend on provider:
#   - openai: gpt-4o-mini
#   - openrouter: openai/gpt-4o-mini
# For OpenRouter you can use any model ID (e.g. anthropic/claude-3-haiku, openai/gpt-4o).
# RECOMO_LLM_MODEL=gpt-4o-mini
