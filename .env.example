# ReCoMo environment variables
# Copy this file to .env and set the values you need.
# If you use python-dotenv, ensure .env is loaded at app start (e.g. the demo does this in run_demo.main()).

# -----------------------------------------------------------------------------
# OpenRouter (LLM API)
# -----------------------------------------------------------------------------

# OpenRouter API key. Get it from https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=sk-or-...

# Model ID for chat/completions. Optional; default: openai/gpt-4o-mini
# Examples: openai/gpt-4o-mini, anthropic/claude-3-haiku, z-ai/glm-5
# RECOMO_LLM_MODEL=openai/gpt-4o-mini
